@namespace Sayeh.AspNetCore.Components
@inherits FluentComponentBase
@typeparam TItem

<FluentAutocomplete TOption="TItem"
                    @ref=_autocomplete
                    IconSearch="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Filled.Size16.TextBulletListTree())"
                    Multiple=false
                    OptionText="DisplayMember.Or(f=> f?.ToString())"
                    @bind-SelectedOption:get="SelectedItem"
                    @bind-SelectedOption:set="f => SetSelectedItem(f)"
                    OnOptionsSearch="OnOptionsSearch"
                    OptionTemplate="ItemTemplate"
                    OptionValue="ValueMember"
                    Label="@Label"
                    AriaLabel="@Label">
    <HeaderContent>
        <FluentButton Class="d-flex" OnClick="OpenDialog">@Resources.SelectFromTree</FluentButton>
    </HeaderContent>
</FluentAutocomplete>