@implements IDialogContentComponent<TItem?>
@typeparam TItem
@namespace Sayeh.AspNetCore.Components
<FluentDialogHeader>
    <FluentDialogBody>
        <SayehTreeView Items="Items"
                       Parent=ParentItem
                       Children="Children"
                       @bind-SelectedItem="Content"
                       ItemTemplate="ItemTemplate"
                       Virtualize=Virtualize 
                       DisplayMember=DisplayMember
                       ChildContent="ChildContent"/>
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton OnClick="CloseModal">@Resources.Select</FluentButton>
    </FluentDialogFooter>
</FluentDialogHeader>