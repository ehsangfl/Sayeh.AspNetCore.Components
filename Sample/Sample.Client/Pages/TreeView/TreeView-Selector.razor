@page "/treeview-selector"
<h3>Multi select TreeView Hierarchy Source</h3>
@if (Items is not null)
{
    <SayehTreeView TItem="HierarchycalItem"
                   Items="Items"
                   Children="f => f.Children"
                   Parent=@(x => x.Parent)
                   DisplayMember="f => f.Name" 
                   SelectProperty="f => f.IsSelected"
                   Virtualize=false
                   ItemChecked="ItemCheckChanged"
                   ItemUnchecked="ItemCheckChanged" />

    <label>@message</label>
}

@code {
    IEnumerable<HierarchycalItem>? Items { get; set; }
    HierarchycalItem SelectedItem { get; set; }
    string message { get; set; }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            Items = HierarchycalItem.GetHierarchycalItems(5, 3);
            SelectedItem = Items.First().Children.Skip(1).First();
            StateHasChanged();
        }

        base.OnAfterRender(firstRender);
    }

    void ItemCheckChanged(HierarchycalItem item)
    {
        message = $"Item {item.Name} is {(item.IsSelected ? "checked" : "unchecked")}";
    }

}
